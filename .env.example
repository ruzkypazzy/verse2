# Verse2 — environment template. Copy to .env and fill in.

# --- Server ---
PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3000

# --- LLM (OpenAI-compatible) ---
# Leave blank to run in mock mode (no LLM calls; deterministic placeholder output).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Audio sidecar ---
SIDECAR_URL=http://127.0.0.1:8077
SIDECAR_TIMEOUT_MS=180000

# --- Receiving wallet (x402 payments on X Layer testnet) ---
RECEIVING_WALLET_ADDRESS=0xREPLACE_WITH_YOUR_XLAYER_TESTNET_ADDRESS
XLAYER_RPC_URL=https://testnet-rpc.xlayer.tech

# --- x402 pricing (USDT0) ---
X402_PACKAGE_PRICE=2.0
X402_REVISION_PRICE=0.3

# --- Storage ---
DATA_DIR=./data
OUTPUT_DIR=./data/outputs
DB_PATH=./data/verse2.db
