{
  "name": "verse2",
  "version": "0.1.0",
  "description": "VERSE2 — Autonomous AI Music Video Creative Director. An OKX.AI ASP (Artistic Excellence).",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "sidecar": "uvicorn server:app --host 127.0.0.1 --port 8077 --app-dir sidecar",
    "test": "vitest run",
    "test:smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@okxweb3/x402-evm": "^0.2.1",
    "@okxweb3/x402-express": "^0.1.0",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.67.0",
    "puppeteer": "^23.6.0",
    "uuid": "^10.0.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
